# Environment variables this project reads at runtime.
# Fill values locally; production secrets live in Cloudflare Wrangler.

GOOGLE_CLIENT_ID=
JWT_SECRET=
VITE_API_URL=http://localhost:8787
VITE_GOOGLE_CLIENT_ID=
TURSO_AUTH_TOKEN=
TURSO_DATABASE_URL=
# Optional separate Turso DB for manga catalog (falls back to TURSO_DATABASE_URL locally)
TURSO_MANGA_AUTH_TOKEN=
TURSO_MANGA_DATABASE_URL=

VITE_SAASMAKER_API_KEY=your-foundry-project-key

# Optional: legacy JSON paths for db:seed and future manga import scripts
DATA_DIR=.
# Homepage A/B test: forces the "treatment" variant (quiz CTA above the fold)
# for ALL visitors. The live 50/50 split uses the `ab_home` cookie by default.
# Leave unset/false for the normal A/B test. See lib/flags.ts.
VITE_HOME_QUIZ_ABOVE_FOLD=false
